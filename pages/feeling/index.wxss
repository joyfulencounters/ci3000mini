.page {
  min-height: 100vh;
  background: #f7f5ef;
  color: #2f2a24;
  padding: 32rpx 32rpx 168rpx;
  box-sizing: border-box;
}

.topbar {
  padding-top: 96rpx;
  padding-bottom: 36rpx;
}

.brand-main {
  display: flex;
  align-items: center;
  justify-content: center;
}

.brand-icon {
  width: 12rpx;
  height: 12rpx;
  background: #6c9f84;
  border-radius: 50%;
  margin: 0 12rpx;
}

.brand-title {
  font-size: 42rpx;
  line-height: 1.3;
  font-weight: 600;
  color: #2f2a24;
  letter-spacing: 6rpx;
}

.brand-sub {
  margin-top: 16rpx;
  text-align: center;
  font-size: 24rpx;
  line-height: 1.8;
  color: #7d7468;
}

.decor {
  margin-top: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.decor-line {
  width: 64rpx;
  height: 1rpx;
  background: rgba(108, 159, 132, 0.28);
}

.decor-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #6c9f84;
  margin: 0 14rpx;
}

.search-box {
  display: flex;
  align-items: center;
  gap: 18rpx;
  margin-bottom: 36rpx;
}

.search-input {
  flex: 1;
  height: 92rpx;
  padding: 0 28rpx;
  background: #fbfaf7;
  border: 2rpx solid #e4dacb;
  border-radius: 26rpx;
  font-size: 30rpx;
  color: #2f2a24;
  box-sizing: border-box;
  box-shadow: 0 6rpx 18rpx rgba(0, 0, 0, 0.03);
}

.search-btn {
  flex: none;
  min-width: 144rpx;
  height: 92rpx;
  line-height: 92rpx;
  text-align: center;
  background: #6c9f84;
  color: #fff;
  border-radius: 26rpx;
  font-size: 30rpx;
  font-weight: 600;
  padding: 0 28rpx;
  box-sizing: border-box;
  box-shadow: 0 10rpx 22rpx rgba(108, 159, 132, 0.22);
}

.result-bar {
  margin-bottom: 20rpx;
  padding: 0 4rpx;
}

.result-text {
  font-size: 24rpx;
  color: #8a8176;
  line-height: 1.6;
}

.state-text {
  padding: 80rpx 20rpx;
  text-align: center;
  font-size: 26rpx;
  color: #8d8478;
  line-height: 1.8;
}

.feeling-list {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  gap: 20rpx 0;
}

.feeling-card {
  width: 48%;
  min-height: 120rpx;
  background: rgba(255, 255, 255, 0.82);
  border: 1rpx solid #ebe3d6;
  border-radius: 24rpx;
  padding: 0 24rpx;
  box-sizing: border-box;

  display: flex;
  align-items: center;
  justify-content: center;
}

.feeling-word {
  font-size: 34rpx;
  line-height: 1.4;
  font-weight: 600;
  color: #2f2a24;
  text-align: center;

  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  width: 100%;
}

.feeling-content {
  margin-top: 12rpx;
  font-size: 26rpx;
  line-height: 1.8;
  color: #6e655b;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 3;
  overflow: hidden;
}

.bottom-switch {
  position: fixed;
  left: 50%;
  bottom: 40rpx;
  transform: translateX(-50%);
  display: flex;
  align-items: center;
  justify-content: center;
  width: auto;
  height: 72rpx;
  background: rgba(255, 255, 255, 0.96);
  border: 1rpx solid #e6dfd2;
  border-radius: 999rpx;
  padding: 6rpx 12rpx;
  gap: 8rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
  z-index: 20;
  box-sizing: border-box;
}

.switch-item {
  padding: 0 24rpx;
  height: 60rpx;
  line-height: 60rpx;
  text-align: center;
  font-size: 26rpx;
  color: #7e766d;
  border-radius: 999rpx;
  flex: none;
}

.switch-item.active {
  background: #6c9f84;
  color: #ffffff;
  font-weight: 600;
}

.load-more-text {
  padding: 24rpx 0 8rpx;
  text-align: center;
  font-size: 24rpx;
  color: #9b9488;
}

.fade-in {
  animation: pageFadeIn 0.26s ease;
}

@keyframes pageFadeIn {
  0% {
    opacity: 0;
    transform: translateY(16rpx);
  }
  100% {
    opacity: 1;
    transform: translateY(0);
  }
}