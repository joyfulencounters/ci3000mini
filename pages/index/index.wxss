page {
  background: #f7f5ef;
}

.page {
  min-height: 100vh;
  background: #f7f5ef;
  color: #2f2a24;
  padding-bottom: 120rpx;
  box-sizing: border-box;
}

/* 顶部 */
/* 顶部容器（最关键） */
.topbar {
  padding-top: 140rpx;   /* ⭐ 再拉开一点，更舒服 */
  padding-bottom: 36rpx;
  background: transparent;   /* 关键：去掉背景 */
}

/* 内容布局 */
.brand {
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 左侧小点（替代logo） */
.brand-icon {
  width: 12rpx;
  height: 12rpx;
  background: #6c9f84;
  border-radius: 50%;
  margin-right: 12rpx;
  margin-left: 12rpx;

  display: inline-block;   /* ⭐ 关键，避免异常渲染 */
  font-size: 0;            /* ⭐ 防止出现黑方块 */
}

/* 主标题 */
.brand-main {
  display: flex;
  align-items: center;
  justify-content: center;
}

.brand-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #2f2f2f;
  letter-spacing: 4rpx;
}

/* 中间分隔线 */
.brand-divider {
  width: 2rpx;
  height: 24rpx;
  background: #d8d8d8;
  margin: 0 16rpx;
}

/* 副标题 */
.brand-sub {
  text-align: center;
  font-size: 22rpx;
  color: #9a9a9a;
  margin-top: 16rpx;
  letter-spacing: 2rpx;
}

/* 主体 */
.main {
  width: 100%;
  box-sizing: border-box;
  padding: 0rpx 36rpx 0;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* 装饰线 */
.decor {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
  margin-top: 30rpx;
  opacity: 0.7;
}

.decor-line {
  width: 64rpx;
  height: 2rpx;
  background: #ddd2c4;
}

.decor-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #b8d6c4;
  margin: 0 20rpx;
}

/* 主卡片 */
.word-card {
  width: 100%;
  max-width: 560rpx;
  min-height: 300rpx;
  border-radius: 32rpx;
  background: linear-gradient(180deg, #eef5f0 0%, #f8f6f1 100%);
  box-shadow: 0 12rpx 40rpx rgba(0, 0, 0, 0.04);
  padding: 50rpx 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 56rpx;
  box-sizing: border-box;
}

.word-center {
  flex: 1;
  text-align: center;
  padding: 0;
}

.word-center.full {
  width: 100%;
}

.word {
  display: block;
  width: 100%;
  text-align: center;

  font-weight: 600;
  color: #2a241d;
  line-height: 1.4;
  margin-bottom: 18rpx;
  opacity: 0.95;
  text-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.03);

  white-space: nowrap;
  letter-spacing: 0;
}

/* 多 tag */
.tags-wrap {
  display: flex;
  justify-content: center;
  flex-wrap: wrap;
  gap: 20rpx;
  margin-top: 10rpx;
}

.tag-chip {
  font-size: 24rpx;
  color: #9a9085;

  padding: 0;
  border: none;
  background: transparent;

  position: relative;
  letter-spacing: 1rpx;
}

.category {
  font-size: 26rpx;
  color: #9c9185;
  letter-spacing: 2rpx;
}

/* 按钮 */
.shuffle-btn {
  margin-top: 10rpx;
  margin-bottom: 60rpx;
  width: 300rpx;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 40rpx;
  background: #1b8f5a;
  color: #fff;
  font-size: 28rpx;
  font-weight: 500;
  box-shadow: 0 8rpx 18rpx rgba(27, 143, 90, 0.18);
  padding: 0;
}

.shuffle-btn::after {
  border: none;
}

.shuffle-btn:active {
  transform: scale(0.96);
  opacity: 0.9;
}

/* 标题 */
.section-title {
  font-size: 28rpx;
  color: #4e7e66;
  margin-bottom: 26rpx;
}

/* 相关词 */
.related {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 18rpx 16rpx;
  max-width: 620rpx;
}

.related-item {
  padding: 12rpx 24rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.7);
  border: 1rpx solid #e8dfd2;
  color: #5f554b;
  font-size: 26rpx;
  line-height: 1.2;
}

.related-item:active {
  transform: scale(0.94);
  background: #f0ece4;
}

/* 空状态 */
.empty {
  color: #b8b0a6;
  font-size: 26rpx;
  margin: 20rpx 0;
}

/* 统计 */
.stats {
  margin-top: 48rpx;
  font-size: 28rpx;
  color: #7b7167;
}

.stats-num {
  color: #16915e;
  font-weight: 700;
}

/* 关于卡片 */
.about-card {
  margin-top: 64rpx;
  width: 100%;
  max-width: 560rpx;
  background: rgba(255, 255, 255, 0.6);
  border: 1rpx solid #e8dfd2;
  border-radius: 28rpx;
  padding: 44rpx 36rpx;
  box-sizing: border-box;
}

.about-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #2f261d;
  margin-bottom: 28rpx;
  letter-spacing: 2rpx;
  text-align: center;
}

.about-text {
  font-size: 28rpx;
  line-height: 1.95;
  color: #6f665d;
  text-align: left;
  margin-bottom: 20rpx;
}

.about-link-label {
  font-size: 26rpx;
  line-height: 1.8;
  color: #8a8177;
  text-align: left;
  margin-top: 8rpx;
}

.about-link {
  font-size: 30rpx;
  color: #6f8f7d;
  text-align: center;
  margin-top: 10rpx;
  letter-spacing: 1rpx;
}



/* 共鸣签整体 */
.tag-section {
  margin-top: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* 标题：共鸣签 */
.tag-title {
  font-size: 22rpx;
  color: #9f968b;

  letter-spacing: 4rpx;

  margin-bottom: 14rpx;

  opacity: 0.9;
}

/* tag 列表 */
.tags-wrap {
  display: flex;
  justify-content: center;
  flex-wrap: wrap;
  gap: 20rpx;
}

/* 单个 tag */
.tag-chip {
  font-size: 24rpx;
  color: #9a9085;
  letter-spacing: 1rpx;
}

.bottom-switch {
  position: fixed;
  left: 50%;
  bottom: 40rpx;
  transform: translateX(-50%);
  display: flex;
  align-items: center;
  justify-content: center;

  /* ⭐ 改这里 */
  width: auto;          /* 或直接删除 width */

  height: 72rpx;
  background: rgba(255, 255, 255, 0.95);
  border: 1rpx solid #e6dfd2;
  border-radius: 999rpx;
  padding: 6rpx 12rpx;  /* ⭐ 左右多一点空间 */
  gap: 8rpx;            /* ⭐ 按钮间距 */

  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
  z-index: 20;
  box-sizing: border-box;
}

.switch-item {
  padding: 0 24rpx;   /* ⭐ 关键：左右留白 */
  height: 60rpx;
  line-height: 60rpx;
  text-align: center;
  font-size: 26rpx;
  color: #7e766d;
  border-radius: 999rpx;
  transition: all 0.2s ease;

  flex: none;          /* ⭐ 不再平均分 */
}

.switch-item.active {
  background: #6c9f84;
  color: #ffffff;
  font-weight: 600;

  box-shadow: 0 4rpx 10rpx rgba(108, 159, 132, 0.3); /* ⭐ 轻微发光 */
}

/* ===== 词单页专属样式 ===== */

.list-card {
  background: #f3f5f2;
  border-radius: 32rpx;
  padding: 44rpx 36rpx 36rpx;
  text-align: center;
  margin-bottom: 36rpx;
  box-shadow: 0 12rpx 30rpx rgba(0, 0, 0, 0.03);
}

.list-badge {
  display: inline-block;
  font-size: 22rpx;
  color: #6c9f84;
  letter-spacing: 4rpx;
  margin-bottom: 20rpx;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(108, 159, 132, 0.10);
}

.list-title {
  font-size: 56rpx;
  line-height: 1.3;
  font-weight: 600;
  color: #2f2a24;
  margin-bottom: 20rpx;
  word-break: break-word;
}

.list-desc {
  font-size: 28rpx;
  line-height: 1.9;
  color: #8d857c;
  margin: 0 auto 28rpx;
  max-width: 88%;
}

.list-meta {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 18rpx;
}

.list-meta-line {
  width: 56rpx;
  height: 2rpx;
  background: #d8d1c6;
}

.list-meta-text {
  font-size: 24rpx;
  color: #9a9288;
  letter-spacing: 2rpx;
}

.wordlist-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 18rpx 16rpx;
  margin-top: 18rpx;
  margin-bottom: 44rpx;
}

.wordlist-chip {
  padding: 14rpx 22rpx;
  border-radius: 999rpx;
  background: #f7f4ee;
  border: 1rpx solid #e8dfd3;
  color: #6f675f;
  font-size: 27rpx;
  line-height: 1.2;
  box-sizing: border-box;
}
.list-hint {
  margin-top: 20rpx;
  text-align: center;
  font-size: 22rpx;
  color: #b0a79c;
  line-height: 1.8;
  letter-spacing: 1rpx;
}

.main {
  transition: opacity 0.2s ease;
}

.main.word {
  opacity: 1;
}

.main.wordlist {
  opacity: 1;
}